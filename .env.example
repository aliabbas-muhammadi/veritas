# Copy to .env.local (gitignored) and fill in. NEVER commit real secrets.
#
# Veritas runs fully KEYLESS by default: the gateway uses a deterministic mock
# provider, and the eval harness reads committed embeddings from disk. Add keys
# only to exercise the live providers + real (OpenAI) embeddings.

# Anthropic key — enables the live primary provider (Claude Haiku) for streamed
# answers. Without it, the gateway serves the deterministic mock provider.
# ANTHROPIC_API_KEY="sk-ant-..."

# OpenAI key — enables (a) the semantic-cache query embedding and (b) the
# secondary/fallback provider (gpt-4o-mini). Without it, the semantic tier is
# inert live (the cache falls back to exact-match only) and the eval semantic
# arm reads the committed embeddings instead.
# OPENAI_API_KEY="sk-..."

# Model overrides (cheap models keep the public demo nearly free).
# GATEWAY_PRIMARY_MODEL="claude-haiku-4-5"   # primary provider, streamed answers
# GATEWAY_FALLBACK_MODEL="gpt-4o-mini"       # failover target
# EMBEDDING_MODEL="text-embedding-3-small"   # semantic-cache embeddings

# Semantic cache: "off" (default — exact tier only, until the P2 rerank guard
# lands) or "on" (Tier-2 cosine matching). Operating cosine threshold for hits.
# SEMANTIC_CACHE="off"
# CACHE_THRESHOLD="0.72"   # recommended operating point: recall 0.97 at FP 0% (eval)

# Eval gate (eval/run.ts). The gateway's gate is the INVERSE of a RAG recall
# gate: it fails the build if the cache serves wrong answers.
# FP_BUDGET="0.02"        # max tolerated false-positive rate at operating tau
# PRECISION_GATE="0.95"   # min tolerated cache-hit precision

# Public site URL (used for metadata / Open Graph).
# NEXT_PUBLIC_SITE_URL="https://gateway.alimuhammadi.com"
